        "title": "Privacy Policy",
        "lastUpdated": "Last updated: March 2025",
        "intro": "This privacy policy explains how the tools on this site handle your data. All tools are designed with privacy in mind — your data stays on your device.",
        "sections": {
            "canvas": {
                "title": "Canvas Editor",
                "body": "The Canvas Editor is a fully client-side tool. All drawing, shapes, arrows, images, and videos you add are processed and stored only in your browser. No canvas data is transmitted to any server. Uploaded images and videos are read locally using the browser File API and are never sent to a remote service."
            },
            "imageProcessor": {
                "title": "Image Manipulator",
                "body": "The Image Manipulator sends your image to an API for conversion processing. The image is used solely to perform the requested conversion and is not stored, logged, or retained on any server after processing is complete. The converted result is returned directly to your browser."
            },
            "directflow": {
                "title": "DirectFlow",
                "body": "DirectFlow is an external application with its own backend. When you interact with DirectFlow, standard web request data (such as IP address and browser type) may be logged by the server as part of normal operation. No personal data is collected beyond what is necessary for the service to function."
            },
            "directflowDocs": {
                "title": "DirectFlow Docs (Mobile App)",
                "body": "DirectFlow Docs is a mobile application for reading PDF, image, and Word documents. All content is stored and accessed entirely on your device. The app does not transmit any data to external servers, does not require an account, and does not collect any personal information. No analytics, crash reporting, or third-party SDKs are used."
            },
            "analytics": {
                "title": "Analytics",
                "body": "This site uses Firebase Analytics to collect anonymous usage data such as page views and general device information. No personally identifiable information is collected. You can opt out by using a browser extension that blocks Google Analytics."
            },
            "contact": {
                "title": "Contact",
                "body": "If you have any questions about this privacy policy, please raise an issue on the project repository or reach out via the contact details on the home page."
            }
        }
    }
